APP_ENV=local
APP_DEBUG=1
APP_TIMEZONE=Europe/Paris

PROJECT_URL=http://localhost
PUBLIC_URL_PREFIX=
TRUSTED_PROXIES=127.0.0.1,::1

DB_TYPE=sqlite
DB_NAME=database/database.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_USER=root
DB_PASSWORD=

LOG_CHANNEL=stderr
LOG_LEVEL=warning
LOG_FORMAT=json
LOG_MAX_FILE_BYTES=10485760
LOG_MAX_FILES=5

API_MAX_BODY_BYTES=1048576
API_TIMEOUT_SECONDS=15
